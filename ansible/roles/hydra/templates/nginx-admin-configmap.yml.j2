apiVersion: v1
kind: ConfigMap
metadata:
  name: hydra-admin-nginx-config
  namespace: {{ NAMESPACE }}
  labels:
    app: hydra
data:
  default.conf: |
    server {
        listen 8445;

        location /health/alive {
            proxy_pass http://localhost:4445;
        }

        location /health/ready {
            proxy_pass http://localhost:4445;
        }

        location /admin/metrics/prometheus {
            proxy_pass http://localhost:4445;
        }

        location / {
            auth_basic "Hydra Admin";
            auth_basic_user_file /etc/nginx/secrets/.htpasswd;
            proxy_pass http://localhost:4445;
        }
    }
